GOOGLE_API_KEY=your_google_api_key_here
OBSIDIAN_API_URL=https://127.0.0.1:27124
OBSIDIAN_API_KEY=your_obsidian_api_key_here
PIXELVAULT_API_KEY=your_api_key_for_wp_bridge
DATABASE_URL=sqlite:///./pixelvault.db
STORAGE_PATH=./storage/images

# Cloudflare R2 — leave blank to use local-only storage
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=pixelvault
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
CDN_DOMAIN=images.noleemits.com

# Supabase JWT — leave blank to disable JWT auth
SUPABASE_JWT_SECRET=
