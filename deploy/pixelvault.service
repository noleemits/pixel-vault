[Unit]
Description=PixelVault API (FastAPI + Uvicorn)
After=network.target

[Service]
User=pixelvault
Group=pixelvault
WorkingDirectory=/opt/pixelvault
EnvironmentFile=/opt/pixelvault/.env
ExecStart=/opt/pixelvault/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
